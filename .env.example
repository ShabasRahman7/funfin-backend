# ----------------------------------------------------------------------------
# CLT LMS FastAPI - environment variables
# Copy this file to `.env` and fill in the real values.
# ----------------------------------------------------------------------------

# App / runtime
ENVIRONMENT=development           # development | production
NODE_ENV=development              # kept for parity with legacy deploy scripts
CLIENT_PORT=5001
ADMIN_PORT=5002
APP_BASE_URL=http://localhost:5001
CLIENT_BASE_URL=http://localhost:5001
ADMIN_BASE_URL=http://localhost:5002

# MongoDB (MongoDB Atlas connection string, must include database name)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lms-backend?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_EXPIRES_IN_MINUTES=10080

# SMTP (OTP + password reset emails)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=CLT Academy <noreply@clt-academy.com>
OTP_EXP_MINUTES=10

# Default admin seed (used by app/scripts/init_default_admin.py)
DEFAULT_ADMIN_FULLNAME=Super Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_ROLE=superadmin

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lms-media
R2_PUBLIC_URL=https://your_public_domain.com

# Legacy Cloudinary keys (kept for back-compat; leave empty if unused)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS allow-list (optional; added on top of built-in defaults)
FRONTEND_URL=https://course.clt-academy.com
ADMIN_URL=https://admin-funfin.vercel.app
